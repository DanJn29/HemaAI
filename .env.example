POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_app_database
TEST_DB_NAME=your_test_database
POSTGRES_HOST_PORT=55432

# Optional direct override if you use a fully managed URL outside Docker.
# Leave commented for normal local development.
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/hema_ai
# TEST_DATABASE_URL=postgresql+psycopg://user:password@host:5432/hema_ai_test

# Component-based application settings. Docker Compose injects matching values
# automatically for the API container, so these are mainly for local non-Docker runs.
DB_HOST=localhost
DB_PORT=55432
DB_NAME=your_app_database
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
TEST_DB_HOST=localhost
TEST_DB_PORT=55432
TEST_DB_NAME=your_test_database
TEST_DB_USER=your_postgres_user
TEST_DB_PASSWORD=your_postgres_password
